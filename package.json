{
  "name": "sollin",
  "version": "1.3.3",
  "description": "Sollin - 跨平台音乐播放器",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run electron:compile",
    "build:web": "tsc && vite build",
    "package": "npm run build && electron-builder",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run package",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "electron:build:mac:x64": "npm run build && electron-builder --mac --x64",
    "electron:build:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "electron:build:win:x64": "npm run build && electron-builder --win --x64",
    "electron:build:linux:x64": "npm run build && electron-builder --linux --x64",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "keywords": [
    "music",
    "player",
    "electron",
    "react"
  ],
  "author": "Sollin Team <noreply@github.com>",
  "license": "MIT",
  "dependencies": {
    "@applemusic-like-lyrics/core": "^0.5.0",
    "@applemusic-like-lyrics/lyric": "^1.0.0",
    "@applemusic-like-lyrics/react": "^0.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-virtual": "^3.13.24",
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "fast-glob": "^3.3.3",
    "framer-motion": "^10.16.16",
    "iconv-lite": "^0.7.2",
    "localforage": "^1.10.0",
    "lucide-react": "^0.294.0",
    "message2call": "^0.1.3",
    "mime-types": "^3.0.2",
    "music-metadata": "^11.10.3",
    "node-forge": "^1.3.3",
    "node-taglib-sharp": "^6.0.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "tailwind-merge": "^2.1.0",
    "ws": "^8.20.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/mime-types": "^3.0.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.sollin.app",
    "productName": "Sollin",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "build/tray-icon.png",
        "to": "build/tray-icon.png"
      },
      {
        "from": "build/Release/qrc_decode.node",
        "to": "build/Release/qrc_decode.node"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Sollin Team <noreply@github.com>",
      "category": "Audio"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
